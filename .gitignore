# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#1053, venv is recommended to be placed at project root
#   Therefore, the following rule should be uncommented
#clean

# poetry
#   According to poetry/poetry#1030, virtualenv is recommended to be placed at project root
#   Therefore, the following rule should be uncommented
#clean

# pdm
.pdm-plugins/
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
